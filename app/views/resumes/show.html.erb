<div class="max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">Your Resume</h1>
    <%= link_to "Edit", edit_resume_path, class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
  </div>

  <% if @resume.content.present? %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-6">
      <div class="text-gray-300 text-sm whitespace-pre-wrap"><%= @resume.content %></div>
    </div>

    <p class="mt-4 text-gray-500 text-sm">
      Last updated: <%= @resume.updated_at.strftime("%b %d, %Y at %I:%M %p") %>
    </p>
  <% else %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-8 text-center">
      <p class="text-gray-400 mb-4">You haven't added your resume yet.</p>
      <p class="text-gray-500 text-sm mb-6">Add your resume to enable AI-powered cover letter generation.</p>
      <%= link_to "Add Resume", edit_resume_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-lg transition-colors" %>
    </div>
  <% end %>
</div>
