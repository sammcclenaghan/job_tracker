<div class="max-w-5xl mx-auto space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Manage Experience Log</h1>
    <p class="text-sm text-gray-500 mt-1">Store raw evidence here. Include extra work that may not appear on your final resume.</p>
  </div>

  <div class="bg-white border border-gh-border rounded-xl p-5 shadow-sm">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Entry</h2>
    <%= form_with model: @experience_entry, url: experience_entries_path, class: "space-y-4" do |f| %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :entry_type, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.select :entry_type, ExperienceEntry::ENTRY_TYPES.map { |t| [t.capitalize, t] }, {}, class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
        <div>
          <%= f.label :title, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.text_field :title, required: true, placeholder: "Full Stack Developer Intern", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
        <div>
          <%= f.label :organization, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.text_field :organization, placeholder: "Leanpub", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
        <div>
          <%= f.label :date_range, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.text_field :date_range, placeholder: "May 2025 - Dec 2025", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :location, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.text_field :location, placeholder: "Victoria, BC", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
        <div>
          <%= f.label :technologies, class: "block text-sm text-gray-700 font-medium mb-1" %>
          <%= f.text_field :technologies, placeholder: "Ruby on Rails, Redis, GraphQL, AWS S3", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
        </div>
      </div>

      <div>
        <%= f.label :tags, class: "block text-sm text-gray-700 font-medium mb-1" %>
        <%= f.text_field :tags, placeholder: "testing, backend, api, infrastructure", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
      </div>

      <div>
        <%= f.label :details, "Evidence / Raw Notes", class: "block text-sm text-gray-700 font-medium mb-1" %>
        <%= f.text_area :details, rows: 8, required: true, placeholder: "- What you built\n- Why it mattered\n- Metrics\n- Edge cases/debugging work\n- Anything that might be relevant to future jobs", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 whitespace-pre-wrap focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
      </div>

      <div class="flex gap-3">
        <%= f.submit "Add Entry", class: "bg-gh-green hover:bg-gh-green-light text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Back", resume_path, class: "text-gray-500 hover:text-gray-700 text-sm px-3 py-2 transition-colors" %>
      </div>
    <% end %>
  </div>

  <div class="space-y-4">
    <% @entries.each do |entry| %>
      <div class="bg-white border border-gh-border rounded-xl p-5 shadow-sm">
        <%= form_with model: entry, url: experience_entry_path(entry), method: :patch, class: "space-y-3" do |f| %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <%= f.select :entry_type, ExperienceEntry::ENTRY_TYPES.map { |t| [t.capitalize, t] }, {}, class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
            <%= f.text_field :title, class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
            <%= f.text_field :organization, placeholder: "Organization", class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
            <%= f.text_field :date_range, placeholder: "Date range", class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
            <%= f.text_field :location, placeholder: "Location", class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
            <%= f.text_field :technologies, placeholder: "Technologies", class: "bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
          </div>
          <%= f.text_field :tags, placeholder: "Tags", class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
          <%= f.text_area :details, rows: 6, class: "w-full bg-white border border-gray-300 rounded-lg px-3 py-2 text-sm text-gray-900 whitespace-pre-wrap focus:outline-none focus:border-gh-green focus:ring-1 focus:ring-gh-green/30" %>
          <div class="flex items-center gap-3">
            <%= f.submit "Save", class: "bg-gray-100 hover:bg-gray-200 text-gray-700 text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors cursor-pointer border border-gray-300" %>
            <%= link_to "Delete", experience_entry_path(entry), data: { turbo_method: :delete, turbo_confirm: "Delete this entry?" }, class: "bg-white hover:bg-red-50 border border-red-300 text-red-600 text-xs font-semibold px-3 py-1.5 rounded-lg transition-colors" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
