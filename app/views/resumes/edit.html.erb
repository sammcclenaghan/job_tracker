<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-white mb-6">Edit Resume</h1>

  <%= form_with model: @resume, url: resume_path, method: :patch, class: "space-y-6" do |f| %>
    <% if @resume.errors.any? %>
      <div class="bg-red-900/50 border border-red-700 text-red-200 px-4 py-3 rounded-lg">
        <ul class="list-disc list-inside text-sm">
          <% @resume.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :content, "Resume Content", class: "block text-sm font-medium text-gray-300 mb-1" %>
      <p class="text-gray-500 text-sm mb-2">Paste your full resume text below. This will be used to generate tailored cover letters.</p>
      <%= f.text_area :content, rows: 25, placeholder: "Paste your resume here...\n\nInclude:\n- Contact information\n- Summary/objective\n- Work experience\n- Education\n- Skills", class: "w-full bg-gray-900 border border-gray-700 rounded-lg px-3 py-2 text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent font-mono text-sm" %>
    </div>

    <div class="flex items-center gap-4">
      <%= f.submit "Save Resume", class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2 rounded-lg transition-colors cursor-pointer" %>
      <%= link_to "Cancel", resume_path, class: "text-gray-400 hover:text-gray-300 transition-colors" %>
    </div>
  <% end %>
</div>
