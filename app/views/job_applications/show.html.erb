<div class="max-w-4xl mx-auto">
  <%# Header with actions %>
  <div class="flex items-start justify-between gap-4 mb-8">
    <div class="flex-1 min-w-0">
      <div class="flex items-start gap-3 mb-2">
        <h1 class="text-2xl font-bold text-white"><%= @job_application.job_title %></h1>
      </div>
      <div class="flex items-center gap-3">
        <p class="text-gray-400 text-lg"><%= @job_application.company_name %></p>
        <span class="<%= @job_application.status_badge_classes %> text-xs font-medium px-2.5 py-0.5 rounded-full shrink-0">
          <%= @job_application.status.capitalize %>
        </span>
      </div>
    </div>

    <div class="flex items-center gap-3 shrink-0">
      <%= link_to "Edit", edit_job_application_path(@job_application), class: "bg-gray-700 hover:bg-gray-600 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
      <%= button_to "Delete", job_application_path(@job_application), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this application?" }, class: "bg-red-600 hover:bg-red-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" %>
    </div>
  </div>

  <%# Status quick actions %>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6" data-controller="status">
    <p class="text-sm text-gray-400 mb-3">Status:</p>
    <div class="flex flex-wrap gap-2">
      <% JobApplication::STATUSES.each do |status| %>
        <% is_current = status == @job_application.status %>
        <button
          type="button"
          data-status-target="button"
          data-status="<%= status %>"
          data-url="<%= update_status_job_application_path(@job_application, status: status) %>"
          data-action="click->status#select"
          class="text-xs font-medium px-3 py-1.5 rounded-full border transition-colors <%= is_current ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-700 text-gray-300 hover:bg-gray-800' %>"
        >
          <%= status.capitalize %>
        </button>
      <% end %>
    </div>
  </div>

  <%# Details grid %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Details</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Location</dt>
          <dd class="text-gray-200"><%= @job_application.location.presence || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Arrangement</dt>
          <dd class="text-gray-200"><%= @job_application.work_arrangement&.capitalize || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Salary</dt>
          <dd class="text-gray-200"><%= @job_application.salary_range.presence || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Contact</dt>
          <dd class="text-gray-200"><%= @job_application.contact_email.presence || "—" %></dd>
        </div>
        <% if @job_application.job_url.present? %>
          <div class="flex justify-between">
            <dt class="text-gray-500">Job URL</dt>
            <dd><%= link_to "View posting", @job_application.job_url, target: "_blank", class: "text-blue-400 hover:text-blue-300" %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Timeline</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Saved</dt>
          <dd class="text-gray-200"><%= @job_application.created_at.strftime("%b %d, %Y") %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Applied</dt>
          <dd class="text-gray-200"><%= @job_application.applied_at&.strftime("%b %d, %Y") || "—" %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Last updated</dt>
          <dd class="text-gray-200"><%= @job_application.updated_at.strftime("%b %d, %Y") %></dd>
        </div>
      </dl>
    </div>
  </div>

  <%# Skills %>
  <% if @job_application.skills_list.any? %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Required Skills</h3>
      <div class="flex flex-wrap gap-2">
        <% @job_application.skills_list.each do |skill| %>
          <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-gray-800 text-gray-300 border border-gray-700">
            <%= skill %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Skills Analysis %>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-medium text-gray-400">Skills Analysis</h3>
      <%= form_with url: generate_skills_analysis_job_application_path(@job_application), method: :post, data: { controller: "loading", action: "submit->loading#submit" } do %>
        <button type="submit" data-loading-target="button" class="text-xs font-medium px-3 py-1.5 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white transition-colors inline-flex items-center gap-2">
          <svg data-loading-target="spinner" class="hidden animate-spin h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span data-loading-target="text"><%= @job_application.has_skills_analysis? ? "Regenerate Analysis" : "Generate with AI" %></span>
        </button>
      <% end %>
    </div>

    <% if @job_application.has_skills_analysis? %>
      <div class="space-y-5">
        <%# Matching Skills %>
        <% if @job_application.matching_skills.any? %>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <h4 class="text-sm font-medium text-green-400">Matching Skills</h4>
            </div>
            <div class="space-y-2">
              <% @job_application.matching_skills.each do |item| %>
                <div class="flex items-start gap-2 pl-6">
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-green-900/50 text-green-300 border border-green-700/50 shrink-0">
                    <%= item["skill"] %>
                  </span>
                  <span class="text-xs text-gray-400"><%= item["explanation"] %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Skills to Highlight %>
        <% if @job_application.skills_to_highlight.any? %>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
              </svg>
              <h4 class="text-sm font-medium text-blue-400">Highlight These</h4>
            </div>
            <div class="space-y-2">
              <% @job_application.skills_to_highlight.each do |item| %>
                <div class="flex items-start gap-2 pl-6">
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-blue-900/50 text-blue-300 border border-blue-700/50 shrink-0">
                    <%= item["skill"] %>
                  </span>
                  <span class="text-xs text-gray-400"><%= item["explanation"] %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <%# Skills to Develop %>
        <% if @job_application.skills_to_develop.any? %>
          <div>
            <div class="flex items-center gap-2 mb-2">
              <svg class="w-4 h-4 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
              </svg>
              <h4 class="text-sm font-medium text-amber-400">Consider Developing</h4>
            </div>
            <div class="space-y-2">
              <% @job_application.skills_to_develop.each do |item| %>
                <div class="flex items-start gap-2 pl-6">
                  <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-900/50 text-amber-300 border border-amber-700/50 shrink-0">
                    <%= item["skill"] %>
                  </span>
                  <span class="text-xs text-gray-400"><%= item["explanation"] %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 text-sm">No skills analysis yet. Click "Generate with AI" to compare your resume against this job's requirements and see what to highlight in your application.</p>
    <% end %>
  </div>

  <%# Job Description %>
  <% if @job_application.job_description.present? %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Job Description</h3>
      <div class="text-gray-300 text-sm whitespace-pre-wrap"><%= @job_application.job_description %></div>
    </div>
  <% end %>

  <%# Application Instructions %>
  <% if @job_application.application_instructions.present? %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Application Instructions</h3>
      <div class="text-gray-300 text-sm whitespace-pre-wrap"><%= @job_application.application_instructions %></div>
    </div>
  <% end %>

  <%# Notes %>
  <% if @job_application.notes.present? %>
    <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6">
      <h3 class="text-sm font-medium text-gray-400 mb-3">Notes</h3>
      <div class="text-gray-300 text-sm whitespace-pre-wrap"><%= @job_application.notes %></div>
    </div>
  <% end %>

  <%# Cover Letter %>
  <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 mb-6" data-controller="clipboard regenerate-modal" data-action="keydown@document->regenerate-modal#closeOnEscape">
    <div class="flex items-center justify-between mb-3">
      <h3 class="text-sm font-medium text-gray-400">Cover Letter</h3>
      <div class="flex items-center gap-2">
        <% if @job_application.cover_letter.present? %>
          <button
            type="button"
            data-clipboard-target="button"
            data-action="click->clipboard#copy"
            class="text-xs font-medium px-3 py-1.5 rounded-lg bg-gray-700 hover:bg-gray-600 text-white transition-colors"
          >
            Copy
          </button>
          <button
            type="button"
            data-action="click->regenerate-modal#open"
            class="text-xs font-medium p-1.5 rounded-lg bg-gray-700 hover:bg-gray-600 text-white transition-colors"
            title="Regenerate with feedback"
          >
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
            </svg>
          </button>
        <% end %>
        <%= form_with url: generate_cover_letter_job_application_path(@job_application), method: :post, data: { controller: "loading", action: "submit->loading#submit" } do %>
          <button type="submit" data-loading-target="button" class="text-xs font-medium px-3 py-1.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-colors inline-flex items-center gap-2">
            <svg data-loading-target="spinner" class="hidden animate-spin h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            <span data-loading-target="text">Generate with AI</span>
          </button>
        <% end %>
      </div>
    </div>
    <% if @job_application.cover_letter.present? %>
      <div data-clipboard-target="source" class="text-gray-300 text-sm whitespace-pre-wrap"><%= @job_application.cover_letter %></div>
    <% else %>
      <p class="text-gray-500 text-sm">No cover letter yet. Click "Generate with AI" to create one based on your resume and this job description.</p>
    <% end %>

    <%# Regenerate with feedback modal %>
    <div data-regenerate-modal-target="modal" data-action="click->regenerate-modal#closeOnBackdrop" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
      <div class="bg-gray-900 border border-gray-700 rounded-xl shadow-xl w-full max-w-md mx-4 p-6">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-base font-semibold text-white">Regenerate Cover Letter</h3>
          <button type="button" data-action="click->regenerate-modal#close" class="text-gray-400 hover:text-white transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
        <p class="text-sm text-gray-400 mb-4">What should be different? (e.g. "emphasize more Rails experience", "make it less generic", "shorter conclusion")</p>
        <%= form_with url: generate_cover_letter_job_application_path(@job_application), method: :post, data: { action: "submit->regenerate-modal#submit" } do |f| %>
          <textarea
            name="feedback"
            data-regenerate-modal-target="feedback"
            rows="3"
            placeholder="Too generic, emphasize my Redis and background job experience more..."
            class="w-full bg-gray-800 border border-gray-700 rounded-lg px-3 py-2 text-sm text-gray-200 placeholder-gray-500 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 resize-none mb-4"
          ></textarea>
          <div class="flex justify-end gap-3">
            <button type="button" data-action="click->regenerate-modal#close" class="text-xs font-medium px-4 py-2 rounded-lg bg-gray-700 hover:bg-gray-600 text-white transition-colors">
              Cancel
            </button>
            <button type="submit" data-regenerate-modal-target="button" class="text-xs font-medium px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-700 text-white transition-colors inline-flex items-center gap-2">
              <svg data-regenerate-modal-target="spinner" class="hidden animate-spin h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span data-regenerate-modal-target="text">Regenerate</span>
            </button>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Back link %>
  <div class="mt-8">
    <%= link_to "← Back to applications", root_path, class: "text-gray-400 hover:text-gray-300 text-sm transition-colors" %>
  </div>
</div>
