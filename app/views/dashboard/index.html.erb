<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">Applications</h1>
  </div>

  <%# Status filter %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "All", root_path, class: "text-xs font-medium px-3 py-1.5 rounded-full border transition-colors #{@current_status.nil? ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-700 text-gray-300 hover:bg-gray-800'}" %>
    <% JobApplication::STATUSES.each do |status| %>
      <%= link_to status.capitalize, root_path(status: status), class: "text-xs font-medium px-3 py-1.5 rounded-full border transition-colors #{@current_status == status ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-700 text-gray-300 hover:bg-gray-800'}" %>
    <% end %>
  </div>

  <% if @applications.any? %>
    <div class="overflow-x-auto rounded-lg border border-gray-800">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-900 text-gray-400 uppercase text-xs tracking-wider">
          <tr>
            <th class="px-4 py-3">Company</th>
            <th class="px-4 py-3">Title</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Location</th>
            <th class="px-4 py-3">Applied</th>
            <th class="px-4 py-3">Arrangement</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800">
          <% @applications.each do |application| %>
            <tr class="bg-gray-950 hover:bg-gray-900 transition-colors">
              <td class="px-4 py-3">
                <%= link_to application.company_name, job_application_path(application), class: "text-white font-medium hover:text-blue-400 transition-colors" %>
              </td>
              <td class="px-4 py-3 text-gray-300"><%= application.job_title %></td>
              <td class="px-4 py-3">
                <span class="<%= application.status_badge_classes %> text-xs font-medium px-2.5 py-0.5 rounded-full">
                  <%= application.status.capitalize %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-400"><%= application.location.presence || "—" %></td>
              <td class="px-4 py-3 text-gray-400">
                <%= application.applied_at&.strftime("%b %d, %Y") || "—" %>
              </td>
              <td class="px-4 py-3 text-gray-400">
                <%= application.work_arrangement&.capitalize || "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-12 text-gray-500">
      <% if @current_status %>
        <p class="mb-4">No <%= @current_status %> applications.</p>
        <%= link_to "View all applications", root_path, class: "text-blue-400 hover:text-blue-300 transition-colors" %>
      <% else %>
        <p class="mb-4">No applications yet.</p>
        <%= link_to "Add your first application", new_job_application_path, class: "text-blue-400 hover:text-blue-300 transition-colors" %>
      <% end %>
    </div>
  <% end %>
</div>
