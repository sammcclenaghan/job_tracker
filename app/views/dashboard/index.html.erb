<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-white">Applications</h1>
    <div class="flex items-center gap-3">
      <%= link_to new_from_paste_job_applications_path, class: "bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        New Application
      <% end %>
    </div>
  </div>

  <%# Status filter %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "All", root_path, class: "text-xs font-medium px-3 py-1.5 rounded-full border transition-colors #{@current_status.nil? ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-700 text-gray-300 hover:bg-gray-800'}" %>
    <% JobApplication::STATUSES.each do |status| %>
      <%= link_to status.capitalize, root_path(status: status), class: "text-xs font-medium px-3 py-1.5 rounded-full border transition-colors #{@current_status == status ? 'bg-blue-600 border-blue-600 text-white' : 'border-gray-700 text-gray-300 hover:bg-gray-800'}" %>
    <% end %>
  </div>

  <% if @applications.any? %>
    <div class="overflow-x-auto rounded-xl border border-gray-800">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-900/50 text-gray-500 uppercase text-[11px] tracking-wider">
          <tr>
            <th class="px-4 py-3">Company</th>
            <th class="px-4 py-3">Title</th>
            <th class="px-4 py-3">Match</th>
            <th class="px-4 py-3">Status</th>
            <th class="px-4 py-3">Location</th>
            <th class="px-4 py-3">Applied</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-800/50">
          <% @applications.each do |application| %>
            <tr class="bg-gray-950 hover:bg-gray-900/50 transition-colors group">
              <td class="px-4 py-3">
                <%= link_to application.company_name, job_application_path(application), class: "text-white font-medium hover:text-blue-400 transition-colors" %>
              </td>
              <td class="px-4 py-3 text-gray-400"><%= application.job_title %></td>
              <td class="px-4 py-3">
                <% if application.match_score.present? %>
                  <% score_color = case application.match_score
                       when 80..100 then "text-green-400"
                       when 60..79 then "text-blue-400"
                       when 40..59 then "text-yellow-400"
                       else "text-red-400"
                     end %>
                  <span class="<%= score_color %> text-xs font-semibold"><%= application.match_score %>%</span>
                <% elsif application.insights_processing? %>
                  <svg class="animate-spin h-3.5 w-3.5 text-gray-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                <% else %>
                  <span class="text-gray-600 text-xs">—</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <span class="<%= application.status_badge_classes %> text-xs font-medium px-2.5 py-0.5 rounded-full">
                  <%= application.status.capitalize %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-500"><%= application.location.presence || "—" %></td>
              <td class="px-4 py-3 text-gray-500">
                <%= application.applied_at&.strftime("%b %d") || "—" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-500">
      <svg class="w-12 h-12 text-gray-700 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
      <% if @current_status %>
        <p class="mb-4">No <%= @current_status %> applications.</p>
        <%= link_to "View all applications", root_path, class: "text-blue-400 hover:text-blue-300 transition-colors text-sm" %>
      <% else %>
        <p class="mb-4">No applications yet.</p>
        <%= link_to "Paste your first job posting", new_from_paste_job_applications_path, class: "text-blue-400 hover:text-blue-300 transition-colors text-sm" %>
      <% end %>
    </div>
  <% end %>
</div>
