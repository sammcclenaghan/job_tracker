<div class="w-full">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Applications</h1>
    <div class="flex items-center gap-3">
      <%= link_to new_from_paste_job_applications_path, class: "bg-gh-green hover:bg-gh-green-light text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors inline-flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
        New Application
      <% end %>
    </div>
  </div>

  <%# Status filter %>
  <div class="flex flex-wrap gap-2 mb-6">
    <%= link_to "All", root_path, class: "text-xs font-semibold px-3 py-1.5 rounded-full border transition-colors #{@current_status.nil? ? 'bg-gh-green border-gh-green text-white' : 'border-gray-300 text-gray-600 hover:bg-gray-100'}" %>
    <% JobApplication::STATUSES.each do |status| %>
      <%= link_to status.capitalize, root_path(status: status), class: "text-xs font-semibold px-3 py-1.5 rounded-full border transition-colors #{@current_status == status ? 'bg-gh-green border-gh-green text-white' : 'border-gray-300 text-gray-600 hover:bg-gray-100'}" %>
    <% end %>
  </div>

  <% if @applications.any? %>
    <div class="overflow-x-auto rounded-xl border border-gh-border bg-white shadow-sm">
      <table class="w-full text-sm text-left">
        <thead class="bg-gray-50 text-gray-500 uppercase text-[11px] tracking-wider border-b border-gh-border">
          <tr>
            <th class="px-4 py-3 font-semibold">Company</th>
            <th class="px-4 py-3 font-semibold">Title</th>
            <th class="px-4 py-3 font-semibold">Match</th>
            <th class="px-4 py-3 font-semibold">Status</th>
            <th class="px-4 py-3 font-semibold">Location</th>
            <th class="px-4 py-3 font-semibold">Applied</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gh-border">
          <% @applications.each do |application| %>
            <tr class="hover:bg-gray-50 transition-colors group">
              <td class="px-4 py-3">
                <%= link_to application.company_name, job_application_path(application), class: "text-gray-900 font-medium hover:text-gh-green transition-colors" %>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= application.job_title %></td>
              <td class="px-4 py-3">
                <% if application.match_score.present? %>
                  <% score_color = case application.match_score
                       when 80..100 then "text-emerald-600"
                       when 60..79 then "text-blue-600"
                       when 40..59 then "text-amber-600"
                       else "text-red-600"
                     end %>
                  <span class="<%= score_color %> text-xs font-semibold"><%= application.match_score %>%</span>
                <% elsif application.insights_processing? %>
                  <svg class="animate-spin h-3.5 w-3.5 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                  </svg>
                <% else %>
                  <span class="text-gray-400 text-xs">--</span>
                <% end %>
              </td>
              <td class="px-4 py-3">
                <span class="<%= application.status_badge_classes %> text-xs font-medium px-2.5 py-0.5 rounded-full">
                  <%= application.status.capitalize %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-500"><%= application.location.presence || "--" %></td>
              <td class="px-4 py-3 text-gray-500">
                <%= application.applied_at&.strftime("%b %d") || "--" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-500">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
      <% if @current_status %>
        <p class="mb-4">No <%= @current_status %> applications.</p>
        <%= link_to "View all applications", root_path, class: "text-gh-green hover:text-gh-green-light transition-colors text-sm font-medium" %>
      <% else %>
        <p class="mb-4">No applications yet.</p>
        <%= link_to "Paste your first job posting", new_from_paste_job_applications_path, class: "text-gh-green hover:text-gh-green-light transition-colors text-sm font-medium" %>
      <% end %>
    </div>
  <% end %>
</div>
