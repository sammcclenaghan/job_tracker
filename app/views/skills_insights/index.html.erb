<div class="w-full">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Skills Insights</h1>
    <p class="text-sm text-gray-500 mt-1">Most requested skills across your job applications — focus on closing the gaps.</p>
  </div>

  <%# Summary stats %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white border border-gh-border rounded-xl p-5 shadow-sm">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Applications Analyzed</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= @applications_with_skills %></p>
      <p class="text-xs text-gray-400 mt-0.5">of <%= @total_applications %> total</p>
    </div>
    <div class="bg-white border border-gh-border rounded-xl p-5 shadow-sm">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Unique Skills Tracked</p>
      <p class="text-2xl font-bold text-gray-900 mt-1"><%= @top_skills.size %></p>
    </div>
    <div class="bg-white border border-gh-border rounded-xl p-5 shadow-sm">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Biggest Gap</p>
      <% biggest_gap = @top_skills.select { |s| s[:missing] > 0 }.max_by { |s| s[:missing] } %>
      <% if biggest_gap %>
        <p class="text-2xl font-bold text-red-600 mt-1"><%= biggest_gap[:name] %></p>
        <p class="text-xs text-gray-400 mt-0.5">missing in <%= biggest_gap[:missing] %> applications</p>
      <% else %>
        <p class="text-2xl font-bold text-emerald-600 mt-1">None!</p>
        <p class="text-xs text-gray-400 mt-0.5">You match all analyzed skills</p>
      <% end %>
    </div>
  </div>

  <% if @top_skills.any? %>
    <% max_count = @top_skills.first[:total] %>

    <div class="bg-white border border-gh-border rounded-xl shadow-sm overflow-hidden">
      <div class="px-5 py-4 border-b border-gh-border">
        <h2 class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Most Requested Skills</h2>
      </div>

      <div class="divide-y divide-gh-border">
        <% @top_skills.each_with_index do |skill, index| %>
          <div class="px-5 py-3.5 flex items-center gap-4">
            <%# Rank %>
            <span class="text-xs font-semibold text-gray-400 w-6 text-right shrink-0"><%= index + 1 %></span>

            <%# Skill name and bar %>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-1.5">
                <span class="text-sm font-semibold text-gray-900 truncate"><%= skill[:name] %></span>
                <span class="text-xs text-gray-400 shrink-0 ml-2">
                  <%= skill[:total] %> <%= skill[:total] == 1 ? "posting" : "postings" %>
                </span>
              </div>
              <%# Frequency bar %>
              <div class="w-full bg-gray-100 rounded-full h-2">
                <div class="bg-gh-green rounded-full h-2 transition-all" style="width: <%= (skill[:total].to_f / max_count * 100).round %>%"></div>
              </div>
            </div>

            <%# Match/gap badges %>
            <div class="flex items-center gap-2 shrink-0">
              <% if skill[:matching] > 0 %>
                <span class="flex items-center gap-1 text-xs font-medium text-emerald-600 bg-emerald-50 border border-emerald-200 px-2 py-0.5 rounded-full">
                  <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                  <%= skill[:matching] %>
                </span>
              <% end %>
              <% if skill[:missing] > 0 %>
                <span class="flex items-center gap-1 text-xs font-medium text-red-600 bg-red-50 border border-red-200 px-2 py-0.5 rounded-full">
                  <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                  <%= skill[:missing] %>
                </span>
              <% end %>
              <% if skill[:matching] == 0 && skill[:missing] == 0 %>
                <span class="text-xs text-gray-400">--</span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Legend %>
    <div class="flex items-center gap-4 mt-4 text-xs text-gray-400">
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
        You have this skill
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
        Skill gap identified
      </span>
    </div>
  <% else %>
    <div class="text-center py-16 text-gray-500">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path></svg>
      <p class="mb-2 font-medium text-gray-600">No skills data yet</p>
      <p class="text-sm">Add job applications with skills to see insights here.</p>
    </div>
  <% end %>
</div>
